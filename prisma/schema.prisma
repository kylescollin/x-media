generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Movie {
  id           Int        @id @default(autoincrement())
  tmdbId       Int        @unique
  title        String
  overview     String?
  posterPath   String?
  backdropPath String?
  releaseDate  String?
  runtime      Int?
  voteAverage  Float?
  genres       String     // JSON array string (SQLite) → Json (Postgres)
  cast         String?    // JSON array, top 10 cast members
  directors    String?    // JSON array
  mediaType       String     @default("movie") // "movie" | "tv"
  numberOfSeasons Int?
  watched      Boolean    @default(true)
  watchedDate  DateTime?
  userRating   Int?       // 1-5 stars
  isFavorite   Boolean    @default(false)
  userNotes    String?
  validated    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tvSeasons    TvSeason[]
}

model TvSeason {
  id              Int     @id @default(autoincrement())
  movieId         Int
  movie           Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  seasonNumber    Int
  episodeCount    Int?
  watchedEpisodes Int     @default(0)
  airDate         String?
  overview        String?
  episodes        String?  // JSON: [{number, name, airDate, watched, stillPath}]

  @@unique([movieId, seasonNumber])
}

model WatchlistItem {
  id            Int      @id @default(autoincrement())
  tmdbId        Int      @unique
  title         String
  mediaType     String   @default("movie")
  posterPath    String?
  backdropPath  String?
  overview      String?
  releaseDate   String?
  runtime       Int?
  genres        String?
  cast          String?  // JSON: CastMember[]
  streamingInfo String?  // JSON: {service, url}[]
  seasons       String?  // JSON: WatchlistTvSeason[] — tracked episode progress
  viewerLabel   String   @default("mine") // "mine" | "ours"
  priority      Int      @default(0)
  addedAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
